import random

print("Welcome to Multiplication Practice!")
print("Type 'q' to quit.\n")

while True:
    num1 = random.randint(1, 100)
    num2 = random.randint(1, 100)

    answer = input(f"What is {num1} * {num2}? ")

    if answer.lower() == 'q':
        print("Goodbye!")
        break
    if int(answer) == num1 * num2:
        print("Correct!\n")
    else:
        print(f"Wrong. The correct answer is {num1 * num2}.\n")

