# Addition
def add(a, b):
    return a + b
# Subtraction
def subtract(a, b):
    return a - b
# Multiplication
def multiplication(a, b):
    return a * b
# Division with error when 0 is inputted
def division(a, b):
    if b == 0:
        raise ValueError("Division by zero is not allowed.")
    return a / b
